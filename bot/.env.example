# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ── Токены Telegram ──────────────────────────────────
BOT_TOKEN=your_production_bot_token_here
TEST_BOT_TOKEN=your_test_bot_token_here

# ── Режим работы ─────────────────────────────────────
# true = тестовый бот + тестовая БД; false = продакшн
TEST_MODE=false

# ── Администраторы бота ───────────────────────────────
# Telegram user_id через запятую (без пробелов)
ADMINS=123456789,987654321

# ── MAX messenger ─────────────────────────────────────
# ID чатов для мониторинга расписания (через запятую)
MAX_WATCH_CHAT_IDS=-1234567890123

# Номер телефона для скрипта test_auth.py (только для диагностики)
# MAX_PHONE=+7XXXXXXXXXX
